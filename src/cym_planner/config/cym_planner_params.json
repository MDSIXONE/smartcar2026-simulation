# CymPlanner 第一阶段参数：局部参考路径 + Footprint 扫掠 + Pure Pursuit
# 修改后重新启动 move_base 即可生效。
{
    "CymPlanner": {
        "base_link_frame": "base_link",

        # 从最近全局路径点向前截取的规划长度，以及近期碰撞检测长度（m）
        "planning_horizon": 2.5,
        "collision_horizon": 1.2,

        # 局部路径等距采样与 Footprint 扫掠插值
        "path_resolution": 0.04,
        "collision_check_step": 0.025,
        "collision_yaw_step": 0.07,
        "transform_timeout": 0.10,

        # Pure Pursuit 速度自适应前视距离
        "lookahead_min": 0.20,
        "lookahead_max": 0.65,
        "lookahead_time": 0.80,
        "tracking_lateral_kp": 1.80,
        "tracking_lateral_kd": 0.12,
        "tracking_heading_kp": 1.20,
        "tracking_heading_kd": 0.08,

        # 第一轮实车/仿真测试使用保守速度，确认碰撞预测稳定后再提高
        "max_vel_x": 0.15,
        "max_vel_theta": 1.00,
        "acc_lim_x": 0.45,
        "dec_lim_x": 0.80,
        "acc_lim_theta": 2.20,
        "dec_lim_theta": 2.80,
        "max_lateral_acceleration": 0.60,

        # 终点停车和朝向对准
        "final_xy_tolerance": 0.05,
        "final_yaw_tolerance": 0.10,
        "final_yaw_gain": 2.0,
        "final_yaw_max_vel": 0.80,

        # 当前阶段无安全路径时先制动，再让 move_base 重新规划/恢复
        "no_path_grace_time": 0.50,
        "no_path_timeout": 1.00,

        # 左右候选、方向锁定与横向偏移细化
        "offset_step": 0.05,
        "max_lateral_offset": 0.50,
        "shift_in_distance": 0.60,
        "shift_out_distance": 0.80,
        "obstacle_pass_margin": 0.35,
        "desired_clearance": 0.18,
        "hard_clearance": 0.08,
        "distance_gradient_step": 0.05,
        "distance_field_update_period": 0.10,
        "optimization_iterations": 12,
        "optimization_step": 0.05,
        "weight_reference": 1.0,
        "weight_smooth": 8.0,
        "weight_obstacle": 12.0,
        "weight_temporal": 5.0,
        "weight_curvature": 8.0,
        "weight_side_cost": 1.0,
        "weight_side_clearance": 0.8,
        "weight_side_distance": 0.25,
        "offset_score_weight": 1.0,
        "curvature_score_weight": 0.50,
        "clearance_score_weight": 0.50,
        "side_change_penalty": 2.0,
        "obstacle_trigger_cycles": 2,
        "side_lock_time": 1.0,
        "clear_hold_time": 0.5,
        "return_time": 0.80,
        "escape_hold_time": 1.20,

        # 载物模式速度缩放，由 /sim_task3/carry_mode 控制
        "carry_speed_scale": 0.80
    }
}
