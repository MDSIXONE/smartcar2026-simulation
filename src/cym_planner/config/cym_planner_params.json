# CymPlanner 局部规划器参数
# 修改本文件后不需要重新编译，只需重新运行 ./start_sim_clean.sh
{
    "CymPlanner": {
        # 机器人本体坐标系
        "base_link_frame": "base_link",

        # 里程计坐标系
        "odom_frame": "odom",

        # 局部控制器直接订阅的二维激光雷达。每帧 /scan 会转成 base_link 下的点云，
        # 用于候选速度轨迹的碰撞检测和评分；不是仅通过 costmap 间接使用。
        "scan_topic": "/scan",

        # 超过该时长未收到新的激光数据，局部控制器必须输出零速度。
        "scan_timeout": 0.4,

        # 参与局部决策的有效激光范围，单位 m。
        "scan_min_range": 0.03,
        "scan_max_range": 3.0,

        # 车体外扩安全距离、制动减速度和控制反应时间。
        # 候选速度的停车距离为 v^2/(2a) + v*t + safety_margin。
        "safety_margin": 0.035,
        "braking_deceleration": 3.0,
        "reaction_time": 0.05,

        # 前视距离，数值越大越平滑，数值越小越贴近路径
        "lookahead_distance": 0.5,

        # 前进速度增益：前方路径点距离乘以该值，决定提速快慢
        "linear_x_gain": 5.0,

        # 当前禁止横向平移，此参数暂不参与车辆控制
        "linear_y_gain": 5.0,

        # 转向增益：数值越大，车头对准路径的力度越强
        "angular_gain": 14.0,

        # 最大前进速度，单位 m/s
        "max_vel_x": 6.0,

        # 当前禁止横向平移，此参数暂不参与车辆控制
        "max_vel_y": 15.0,

        # 最大旋转速度，单位 rad/s
        "max_vel_theta": 15.5,

        # 到达路径终点后的独立朝向对准参数。
        # final_yaw_gain 越大，终点旋转越快；建议 1.5 ~ 3.0。
        "final_yaw_gain": 12.0,

        # 终点旋转速度上限，单位 rad/s；建议 0.8 ~ 1.5。
        "final_yaw_max_vel": 10.2,

        # 终点方向误差小于该值即视为完成，单位 rad。
        "final_yaw_tolerance": 0.10,

        # 终点方向对准时保留的前后微调增益；设为 0 可只原地旋转。
        "final_linear_x_gain": 1.5,

        # 终点位置误差小于该值后，局部控制切换到末端朝向对正。
        "goal_position_tolerance": 0.05,

        # 任务节点在夹取完成后发布 /sim_task3/carry_mode=true。
        # 载物通过障碍物加工区时，前进、转向和终点对正最高速度均乘以此值。
        "carry_speed_scale": 0.80,

        # 车头方向容差，单位 rad；当前边走边转逻辑中保留备用
        "heading_tolerance": 0.20,

        # 局部轨迹模拟时长和步长，单位秒。每个候选 (v, w) 都会以此轨迹
        # 对激光点云做车体扫掠碰撞检测。
        "simulation_time": 0.3,

        # 局部轨迹模拟步长，单位秒
        "simulation_step": 0.05,

        # 速度采样数量。更多采样能绕开动态障碍，但会增加控制器计算量。
        "v_samples": 7,
        "w_samples": 9,

        # 激光轨迹评分：路径贴合、朝向、障碍净空、速度和转向平滑性。
        "path_distance_weight": 4.0,
        "heading_weight": 0.8,
        "clearance_weight": 0.5,
        "velocity_weight": 0.5,
        "angular_velocity_weight": 0.05,

        # costmap 只作为全局重规划的辅助约束；局部速度安全性由上面的激光点云轨迹检测决定。
        # 沿全局路径向前检查的实际距离，单位 m，命中障碍后请求 move_base 重规划。
        "obstacle_lookahead_distance": 0.30,

        # 253 覆盖膨胀区，254 为致命障碍；代码按 cost >= 此值判定
        "obstacle_cost_threshold": 253
    }
}
