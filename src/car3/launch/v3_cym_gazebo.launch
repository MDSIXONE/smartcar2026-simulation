<launch>
  <arg name="gui" default="true"/>
  <arg name="rviz" default="true"/>
  <arg name="debug" default="false"/>
  <!-- Keep the arm passive while the task vehicle drives to the pickup bay. -->
  <arg name="start_arm_controllers" default="true"/>
  <arg name="set_initial_arm_pose" default="true"/>
  <arg name="hold_initial_arm_pose" default="false"/>
  <!-- Calibrated parked posture.  It is set once, then arm control remains
       stopped until a pick task explicitly enables it. -->
  <arg name="arm_initial_positions" default="-0.0001,-0.4999,1.2800,1.7000,0.0000"/>
  <arg name="initial_pose_duration" default="6.0"/>
  <arg name="initial_transition_steps" default="2"/>
  <arg name="direct_initial_configuration" default="false"/>
  <arg name="disable_arm_gravity" default="true"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find car3)/world/math.world"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="gui" value="$(arg gui)"/>
  </include>

  <param name="robot_description" textfile="$(find car3)/urdf/car3.urdf"/>
  <env name="GAZEBO_MODEL_PATH" value="$(find car3)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
        args="-param robot_description -urdf -model car3 -x 0 -y 0 -z 0.01" output="screen"/>
  <node name="spawn_cubes" pkg="car3" type="spawn_cubes.py" output="screen"/>
  <node name="reset_car_start" pkg="car3" type="reset_car_start.py" output="screen" required="false">
    <param name="model_name" value="car3"/>
    <param name="start_x" value="0.0"/>
    <param name="start_y" value="0.0"/>
    <param name="start_z" value="0.01"/>
    <param name="start_yaw" value="0.0"/>
  </node>
  <!-- One Gazebo configuration call: set the v2 initial posture before any
       arm/gripper controller is started.  It never publishes controller commands. -->
  <node if="$(arg set_initial_arm_pose)" name="set_arm_initial_pose" pkg="car3"
        type="set_arm_initial_pose.py" output="screen" required="false">
    <param name="arm_initial_positions" value="$(arg arm_initial_positions)"/>
    <param name="gripper_open_position" value="1.0"/>
    <param name="disable_arm_gravity" value="$(arg disable_arm_gravity)"/>
    <param name="hold_initial_pose" value="$(arg hold_initial_arm_pose)"/>
    <param name="hold_rate" value="30.0"/>
    <param name="controller_duration" value="$(arg initial_pose_duration)"/>
    <param name="transition_steps" value="$(arg initial_transition_steps)"/>
    <param name="direct_initial_configuration" value="$(arg direct_initial_configuration)"/>
    <param name="controller_command_repeats" value="8"/>
  </node>

  <rosparam file="$(find car3)/config/car3_control.yaml" command="load"/>
  <group if="$(arg start_arm_controllers)">
    <node name="controller_spawner" pkg="controller_manager" type="spawner"
          args="joint_state_controller arm_controller gripper_controller" output="screen"/>
  </group>
  <group unless="$(arg start_arm_controllers)">
    <node name="joint_state_controller_spawner" pkg="controller_manager" type="spawner"
          args="joint_state_controller" output="screen"/>
    <node name="deferred_arm_controller_loader" pkg="controller_manager" type="spawner"
          args="--stopped arm_controller gripper_controller" output="screen"/>
  </group>
  <node name="gripper_mimic" pkg="car3" type="gripper_mimic.py" output="screen"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <remap from="joint_states" to="joint_states_full"/>
    <param name="publish_frequency" value="50.0"/>
  </node>
  <node name="grasp_attach" pkg="car3" type="grasp_attach.py" output="screen">
    <rosparam param="object_models">['cube_0', 'cube_1', 'cube_2']</rosparam>
  </node>
  <node name="fake_joint_calibration" pkg="rostopic" type="rostopic"
        args="pub /calibrated std_msgs/Bool true"/>

  <include file="$(find gazebo_nav)/launch/v3_cym_nav.launch">
    <arg name="rviz" value="$(arg rviz)"/>
  </include>
</launch>
