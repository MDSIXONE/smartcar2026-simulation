    <mu2>1.0</mu2>
    <kp>1e6</kp>
    <kd>1e5</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>
  <gazebo reference="wheel_rf_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
